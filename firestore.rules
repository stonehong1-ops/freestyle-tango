service cloud.firestore {
  match /databases/{database}/documents {
    // [Rules] Allow public read for essential data
    match /milonga_info/{docId} { allow read: if true; }
    match /media/{docId} { allow read: if true; }
    match /tango_classes/{docId} { allow read: if true; }
    match /extra_schedules/{docId} { allow read: if true; }
    match /monthly_notices/{docId} { allow read: if true; }
    
    // [Rules] More strict for reservations and users
    match /milonga_reservations/{docId} {
      allow read, write: if true; 
    }
    match /users/{userId} {
      allow read, write: if true; 
    }
    match /chat_rooms/{roomId} {
      allow read, write: if true;
    }
    match /chat_messages/{messageId} {
      allow read, write: if true;
    }
    match /coaching_items/{itemId} {
      allow read, write: if true;
    }
    match /coaching_updates/{updateId} {
      allow read, write: if true;
    }
    
    // FCM Tokens
    match /fcm_tokens/{tokenId} {
      allow read, write: if true;
    }
    match /fcm_errors/{errorId} {
      allow create: if true;
    }
    
    // Default fallback
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
